PROJECT_NAME           = "IdTech4 Remaster"
PROJECT_NUMBER         = "@IDTECH4_DOXYGEN_PROJECT_NUMBER@"
PROJECT_BRIEF          = "API reference generated from the IdTech4 Remaster source tree"
OUTPUT_DIRECTORY       = "@IDTECH4_DOXYGEN_OUTPUT_DIR@"
OUTPUT_LANGUAGE        = English
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = NO
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = "@CMAKE_SOURCE_DIR@"
TAB_SIZE               = 4

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_PRIV_VIRTUAL   = NO
EXTRACT_PACKAGE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
INTERNAL_DOCS          = NO
CASE_SENSE_NAMES       = YES

INPUT                  = @IDTECH4_DOXYGEN_INPUT@
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.h *.hh *.hpp *.hxx *.inl
RECURSIVE              = YES
EXCLUDE                = @IDTECH4_DOXYGEN_EXCLUDE@
EXCLUDE_SYMLINKS       = YES
EXCLUDE_PATTERNS       = */build/* */_deps/* */.git/*

SOURCE_BROWSER         = NO
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
REFERENCES_LINK_SOURCE = YES
USE_HTAGS              = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = @IDTECH4_DOXYGEN_HTML_OUTPUT@
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
SEARCHENGINE           = YES
SERVER_BASED_SEARCH    = NO

GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO
EXPAND_ONLY_PREDEF     = NO
SKIP_FUNCTION_MACROS   = YES

QUIET                  = YES
WARNINGS               = NO
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

HAVE_DOT               = NO
UML_LOOK               = NO
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
